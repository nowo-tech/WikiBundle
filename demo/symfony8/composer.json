{
    "name": "nowo-tech/wiki-demo-symfony8",
    "description": "Demo for Wiki Bundle - Symfony 8.1",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "/var/wiki-bundle",
            "options": {
                "symlink": true,
                "versions": {
                    "nowo-tech/wiki-bundle": "1.0.0"
                }
            }
        },
        {
            "type": "path",
            "url": "/var/tiptap-editor-bundle",
            "options": {
                "symlink": true,
                "versions": {
                    "nowo-tech/tiptap-editor-bundle": "1.0.0"
                }
            }
        }
    ],
    "require": {
        "php": ">=8.4,<8.6",
        "doctrine/doctrine-bundle": "^2.10 || ^3.0",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "doctrine/doctrine-migrations-bundle": "^3.3 || ^4.0",
        "doctrine/migrations": "^3.8",
        "doctrine/orm": "^3.0",
        "nowo-tech/wiki-bundle": "^1.0",
        "nowo-tech/tiptap-editor-bundle": "^1.0",
        "symfony/ai-agent": "^0.1",
        "symfony/ai-bundle": "^0.1",
        "symfony/ai-open-ai-platform": "^0.1",
        "symfony/ai-ollama-platform": "^0.1",
        "symfony/asset": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2.0",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/security-csrf": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*"
    },
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "database": [
            "@php bin/console doctrine:database:create --if-not-exists",
            "@php bin/console doctrine:migrations:migrate --no-interaction"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
