APP_ENV=dev
APP_DEBUG=true

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker
APP_SECRET=change_this_secret_key_to_a_random_value
PORT=8025
DEFAULT_URI=http://localhost:8025
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wiki_demo
MYSQL_USER=demo
MYSQL_PASSWORD=demo
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4
# Wiki AI (symfony/ai-bundle) — set one provider:
OPENAI_API_KEY=
OLLAMA_HOST_URL=http://host.docker.internal:11434
