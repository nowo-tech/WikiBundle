<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'wiki.title'|trans({}, 'NowoWikiBundle') }}{% endblock %}</title>
    {% block styles %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
        <link rel="stylesheet" href="{{ asset('wiki.css', 'nowo_wiki') }}">
        <style>
            body { background: #f6f8fb; }
            .container-narrow { max-width: 960px; }
            .container-wiki { max-width: 1180px; }
        </style>
    {% endblock %}
</head>
<body>
<div class="page">
    <div class="{% block container_class %}container container-wiki{% endblock %} py-4">
        {% block body %}{% endblock %}
    </div>
</div>
{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="{{ asset('wiki.js', 'nowo_wiki') }}" defer></script>
    {% block wiki_editor_scripts %}{% endblock %}
{% endblock %}
</body>
</html>
