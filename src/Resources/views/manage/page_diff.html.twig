{% extends layout %}

{% block title %}{{ 'wiki.diff.title'|trans({}, 'NowoWikiBundle') }}{% endblock %}

{% block container_class %}container container-narrow{% endblock %}

{% block body %}
    {% include '@NowoWikiBundle/manage/_page_header.html.twig' with {
        page_title: 'wiki.diff.title'|trans({}, 'NowoWikiBundle'),
        page_subtitle: 'v' ~ from_revision.revisionNumber ~ ' → v' ~ to_revision.revisionNumber,
    } %}

    <div class="card">
        <div class="card-body wiki-diff-list">
            {% for line in diff %}
                <span class="wiki-diff-{{ line.kind }}">{{ line.kind|upper }} {{ line.line }}</span>
            {% endfor %}
        </div>
        <div class="card-footer">
            <a href="{{ path(routes.page_history.name, {spaceSlug: space.slug, pageSlug: page.slug}) }}" class="btn btn-outline-secondary">
                <i class="ti ti-arrow-left me-1" aria-hidden="true"></i>{{ 'wiki.history.title'|trans({}, 'NowoWikiBundle') }}
            </a>
        </div>
    </div>
{% endblock %}
