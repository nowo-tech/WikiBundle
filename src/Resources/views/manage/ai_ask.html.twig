{% extends layout %}

{% block title %}{{ 'wiki.ai.title'|trans({}, 'NowoWikiBundle') }}{% endblock %}

{% block body %}
    {% include '@NowoWikiBundle/manage/_page_header.html.twig' with {
        page_title: 'wiki.ai.title'|trans({}, 'NowoWikiBundle'),
        page_subtitle: 'wiki.ai.intro'|trans({}, 'NowoWikiBundle'),
        show_search: true,
    } %}

    {% if error %}
        <div class="alert alert-warning mb-4" role="alert">{{ error|trans({}, 'NowoWikiBundle') }}</div>
    {% endif %}

    {% if answer %}
        <div class="card mb-4">
            <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                <h2 class="card-title mb-0">{{ 'wiki.ai.answer_title'|trans({}, 'NowoWikiBundle') }}</h2>
                <a href="{{ path(routes.index.name) }}" class="btn btn-sm btn-outline-azure">
                    <i class="ti ti-sparkles me-1" aria-hidden="true"></i>{{ 'wiki.ai.open'|trans({}, 'NowoWikiBundle') }}
                </a>
            </div>
            <div class="card-body">
                <p class="text-secondary small mb-2"><strong>{{ question }}</strong></p>
                <div class="wiki-ai-answer">{{ answer|nl2br }}</div>
            </div>
        </div>

        {% if sources is not empty %}
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title mb-0">{{ 'wiki.ai.sources_title'|trans({}, 'NowoWikiBundle') }}</h3>
                </div>
                <div class="list-group list-group-flush">
                    {% for hit in sources %}
                        <a href="{{ path(routes.page_view.name, {spaceSlug: hit.space.slug, pageSlug: hit.page.slug}) }}" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <strong>{{ hit.page.title }}</strong>
                                <span class="text-secondary small">{{ hit.space.name }}</span>
                            </div>
                            <p class="mb-0 text-secondary small">{{ hit.excerpt }}</p>
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <div class="card border-azure">
            <div class="card-header">
                <h3 class="card-title mb-0">{{ 'wiki.ai.follow_up'|trans({}, 'NowoWikiBundle') }}</h3>
            </div>
            <div class="card-body">
                <form action="{{ path(routes.ai_ask.name) }}" method="post" class="mb-0">
                    {% include '@NowoWikiBundle/manage/_ai_ask_form_fields.html.twig' %}
                </form>
            </div>
        </div>
    {% else %}
        <div class="card border-azure">
            <div class="card-body">
                <form action="{{ path(routes.ai_ask.name) }}" method="post" class="mb-0">
                    {% include '@NowoWikiBundle/manage/_ai_ask_form_fields.html.twig' %}
                </form>
                <p class="text-secondary small mt-3 mb-0">{{ 'wiki.ai.help'|trans({}, 'NowoWikiBundle') }}</p>
            </div>
        </div>
    {% endif %}
{% endblock %}
