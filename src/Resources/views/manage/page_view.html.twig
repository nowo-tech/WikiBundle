{% extends layout %}

{% block title %}{{ page.title }}{% endblock %}

{% block body %}
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card" data-wiki-sidebar>
                <div class="card-header">
                    <a href="{{ path(routes.space.name, {spaceSlug: space.slug}) }}" class="text-reset">
                        <i class="ti ti-arrow-left me-1" aria-hidden="true"></i>{{ space.name }}
                    </a>
                </div>
                <div class="card-body py-2">
                    <nav aria-label="{{ 'wiki.space.pages'|trans({}, 'NowoWikiBundle') }}">
                        {% include '@NowoWikiBundle/manage/_page_tree.html.twig' with {tree: tree|default([]), space: space, routes: routes} only %}
                    </nav>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <h2 class="card-title mb-0">{{ page.title }}</h2>
                    <div class="btn-list">
                        {% if can_edit %}
                            <a href="{{ path(routes.page_edit.name, {spaceSlug: space.slug, pageSlug: page.slug}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="ti ti-pencil me-1" aria-hidden="true"></i>{{ 'wiki.page.edit'|trans({}, 'NowoWikiBundle') }}
                            </a>
                        {% endif %}
                        {% if can_history %}
                            <a href="{{ path(routes.page_history.name, {spaceSlug: space.slug, pageSlug: page.slug}) }}" class="btn btn-sm btn-outline-secondary">
                                <i class="ti ti-history me-1" aria-hidden="true"></i>{{ 'wiki.page.history'|trans({}, 'NowoWikiBundle') }}
                            </a>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body wiki-page-content">
                    {{ revision ? revision.contentHtml|raw : '' }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
